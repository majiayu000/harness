{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.local/schemas/pr_review_gate.schema.json",
  "title": "Pull Request Review Gate",
  "type": "object",
  "required": [
    "pr",
    "state",
    "is_draft",
    "linked_issue",
    "head_sha",
    "merge_state",
    "checks",
    "reviews",
    "review_threads"
  ],
  "additionalProperties": false,
  "properties": {
    "pr": {
      "type": "integer",
      "minimum": 1
    },
    "linked_issue": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "state": {
      "type": "string",
      "minLength": 1
    },
    "is_draft": {
      "type": "boolean"
    },
    "head_sha": {
      "type": "string",
      "minLength": 7
    },
    "merge_state": {
      "type": "string",
      "minLength": 1
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "conclusion"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "conclusion": {
            "type": "string"
          }
        }
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["author", "state"],
        "additionalProperties": true,
        "properties": {
          "author": {
            "type": "string",
            "minLength": 1
          },
          "state": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review_threads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["is_resolved", "is_outdated"],
        "additionalProperties": true,
        "properties": {
          "url": {
            "type": "string"
          },
          "is_resolved": {
            "type": "boolean"
          },
          "is_outdated": {
            "type": "boolean"
          }
        }
      }
    },
    "human_authorization": {
      "type": ["object", "null"],
      "required": ["actor", "source"],
      "additionalProperties": true,
      "properties": {
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        }
      }
    }
  }
}
